NODE_ENV=production
PORT=3000

# Database — Turso (LibSQL)
# Local dev: use file:// protocol (no auth token needed)
# Production: get URL + token from turso.tech
# TURSO_DATABASE_URL is also accepted for Vercel Marketplace installs.
TURSO_URL=file:./server/data/dev.db
TURSO_AUTH_TOKEN=

# JWT secrets — generate two long random strings
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

FRONTEND_URL=http://localhost:5173
