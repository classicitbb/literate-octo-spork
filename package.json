{
  "name": "pricesmart-optical",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:staging": "node --env-file=.env.staging node_modules/.bin/nodemon server/index.js",
    "dev:client": "vite client --config client/vite.config.js",
    "build": "vite build client --mode production",
    "build:staging": "vite build client --mode staging",
    "start": "node server/index.js",
    "start:staging": "node --env-file=.env.staging server/index.js",
    "migrate": "node scripts/migrate.js",
    "migrate:staging": "node --env-file=.env.staging scripts/migrate.js",
    "seed:staging": "node --env-file=.env.staging scripts/seed-dev.js",
    "create-tenant": "node scripts/create-tenant.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^5.3.2",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.1.6"
  }
}
